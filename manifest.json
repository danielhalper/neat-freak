{
  "manifest_version": 3,
  "name": "Neat Freak",
  "version": "1.3.0",
  "description": "Intelligently stashes and organizes the tabs you're done with into tidy folders by project. Restore any of them in one click.",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "https://api.openai.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Neat Freak",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": [
        "assets/mascot-stressed-128.png",
        "assets/mascot-calm.svg",
        "assets/logo.svg",
        "assets/fonts/PermanentMarker-Regular.woff2",
        "assets/fonts/LilitaOne-Regular.woff2"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
